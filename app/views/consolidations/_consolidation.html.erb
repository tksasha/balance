<div class="consolidations-item <%= 'consolidations-item-income' if consolidation.income? %>">
  <div class="consolidations-item-label">
    <%= consolidation.name %>
  </div>

  <%= link_to_if consolidation.slug,
    money(consolidation.sum), "/#{ consolidation.year }/#{ consolidation.month }/#{ consolidation.slug }", remote: true %>
</div>
