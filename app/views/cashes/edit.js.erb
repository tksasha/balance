(function() {
  var $modal = $('#modal');

  $modal.modal({
    onOpenStart: function() {
      $modal.width('40%');
    },
    onOpenEnd: function() {
      $('#cash_name').focus();

      $('#cash_formula').focus();
    }
  });

  $modal.find('.modal-content').html('<%= j render 'edit' %>');

  $modal.modal('open');
}());
