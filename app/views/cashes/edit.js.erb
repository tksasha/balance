(function() {
  Modal.options.onOpenStart = function() {
    Modal.el.style.width = '40%';
  };

  Modal.options.onOpenEnd = function() {
    $('#cash_name').focus();

    $('#cash_formula').focus();
  };

  Modal.options.onCloseStart = function() {
    Modal.options.onOpenStart = null;

    Modal.options.onOpenEnd = null;
  };

  $(Modal.el).children('.modal-content').html('<%= j render 'edit' %>');

  Modal.open();
}());
