(function() {
  $('.modal .modal-title').text('Змінити залишок');

  $('.modal .modal-body').html('<%= j render 'form' %>');

  $('.modal .modal-dialog').removeClass('modal-lg');

  $('.modal').on('shown.bs.modal', function() {
    $('#cash_formula').focus();
  });

  if(!$('.modal').hasClass('show')) {
    $('.modal').modal();
  }
}());
