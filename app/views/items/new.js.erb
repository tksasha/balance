(function() {
  Modal.options.onOpenStart = function() {
    Modal.el.style.width = '30%';
  }

  Modal.options.onCloseStart = function() {
    var select = $('#modal .modal-content select').first();

    M.FormSelect.getInstance(select).destroy();
  }

  $(Modal.el).
    children('.modal-content').
    html('<%= j render 'form' %>').
    custom(function() {
      $('.datepicker').datepicker(DatepickerDefaultOptions);

      $('#modal .modal-content select').formSelect(FormSelectDefaultOptions);

      M.updateTextFields();
    });

  Modal.open();
}());
