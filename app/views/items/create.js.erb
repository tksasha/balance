(function() {
  $('#items').html('<%= j render items(DateRange.new(resource.date).month) %>');

  $('#at_end').html('<%= money Cash.at_end %>');

  $('#balance').html('<%= money Cash.balance %>');

  $.getScript('<%= url_for [:consolidations, year: params[:year], month: params[:month]] %>');

  $('#item-inline-form').find('form').trigger('reset');

  $('#item-inline-form').find('select').selectpicker('render');

  $('.modal').modal('hide');
}());
