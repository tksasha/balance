(function() {
  $.getScript('<%= consolidations_path(year: resource.date.year, month: resource.date.month) %>');

  $.getScript('<%= items_path(year: resource.date.year, month: resource.date.month) %>');

  $('#item-inline-form').
    find('form').
    trigger('reset');

  const el = document.querySelector('.modal');

  bootstrap.
    Modal.
    getInstance(el).
    hide();

  setTimeout(function() {
    $('#at_end').html('<%= money at_end %>');

    $('#balance').html('<%= money balance %>');
  }, 100);
}());
