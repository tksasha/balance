(function() {
  $('#at_end').html('<%= money Cash.at_end %>');

  $('#balance').html('<%= money Cash.balance %>');

  $.getScript('<%= url_for [:consolidations, year: resource.date.year, month: resource.date.month] %>');

  $.getScript('<%= url_for [:items, year: resource.date.year, month: resource.date.month] %>');

  $('#item-inline-form').find('form').trigger('reset');

  $('#item-inline-form').find('select').selectpicker('render');

  $('.modal').modal('hide');
}());
