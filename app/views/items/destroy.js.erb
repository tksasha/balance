(function() {
  $('#item_<%= resource.id %>').remove();

  $('.modal').modal('hide');

  $('#at_end').html('<%= money(dashboard.at_end) %>');

  $('#balance')
    .html('<%= money(dashboard.balance) %>')
    .trigger('balance.changed');

  $('#consolidations')
    .html('<%= j render partial: 'consolidations/consolidations', collection: dashboard.consolidations %>')
    .trigger('consolidations.changed');
}());
