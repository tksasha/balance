(function() {
  $('#item_<%= resource.id %>').remove();

  $.getScript('<%= consolidations_path(year: resource.date.year, month: resource.date.month) %>');

  $('.modal').modal('hide');

  $('#at_end').html('<%= money(dashboard.at_end) %>');

  $('#balance').html('<%= money(dashboard.balance) %>');

  $('#balance').trigger('balance.changed');
}());
