(function() {
  $('header').replaceWith('<%= j render 'widgets/header' %>');

  <% if collection.any? %>
    $('#items').html('<%= j render collection %>');
  <% else %>
    $('#items').html('<%= j render 'not_found' %>');
  <% end %>

  $.getScript('<%= url_for [:consolidations, year: params[:year], month: params[:month]] %>');
}());
