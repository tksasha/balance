(function() {
  $('header').replaceWith('<%= j render 'widgets/header' %>');

  <% if collection.any? %>
    $('#items').html('<%= j render collection.decorate %>');
  <% else %>
    $('#items').html('<%= j render 'not_found' %>');
  <% end %>

  $('#consolidations')
    .html('<%= j render partial: 'consolidations/consolidations', collection: dashboard.consolidations %>')
}());
