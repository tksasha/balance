$(function() {
  $('.modal-body').html('<%= j render 'form' %>');

  $('.modal').find('.datepicker').datepicker(BOOTSTRAP_DATEPICKER_DEFAULTS);

  $('.modal').find('select').selectpicker();

  $('.modal').on('shown.bs.modal', function() {
    $('.modal')
      .find('#item_formula')
      .focus(function() { $(this).select() })
      .focus();

    <%# $('.modal').find('#item_formula').focus(); %>
  }).modal('show');
}());
