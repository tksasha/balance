(function() {
  const el = document.querySelector('.modal');

  document.
    querySelector('.modal-header').
    classList.
    add('d-none');

  document.
    querySelector('.modal-dialog').
    classList.
    remove('modal-lg');

  document.
    querySelector('.modal-footer').
    classList.
    add('d-none');

  document.
    querySelector('.modal-body').
    innerHTML = '<%= j render 'form' %>';

  const form = el.querySelector('form');

  form.
    querySelector('#tags-spinner').
    classList.
    remove('d-none');

  items.tags.Reset(form);

  const tag_ids = JSON.parse('<%= resource.tag_ids %>');

  const url = '<%= url_for [resource.category, :tags] %>';

  items.tags.Load(form, url, tag_ids);

  const show = function() {
    $('.modal').
      find('.datepicker').
      datepicker(BOOTSTRAP_DATEPICKER_DEFAULTS);

    $('.modal')
      .find('#item_formula')
      .focus();

    document.
      querySelector('.modal-body #item_category_id').
      addEventListener('change', function() { items.category.OnChange(form) });
  };

  const hide = function() {
    el.removeEventListener('shown.bs.modal', show);

    el.removeEventListener('hide.bs.modal', hide);
  }

  el.addEventListener('shown.bs.modal', show);

  el.addEventListener('hide.bs.modal', hide);

  const modal = bootstrap.Modal.getOrCreateInstance(el);

  modal.show();
}());
