(function() {
  document
    .querySelector('.modal-dialog')
    .classList
    .remove('modal-lg');

  document.
    querySelector('.modal-title').
    innerText = '<%= t(params[:supercategory], scope: 'cash.supercategory') %>';

  document
    .querySelector('.modal-body')
    .innerHTML = '<%= j render partial: 'cash', collection: %>';

  bootstrap.Modal.Show();
}());
