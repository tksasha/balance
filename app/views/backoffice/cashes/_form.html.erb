<%= form_for [:backoffice, resource], remote: true, html: { autocomplete: :off } do |f| %>
  <div class="form-group">
    <%= input(f, :name) %>
  </div>

  <div class="form-group mt-3">
    <%= f.label :supercategory %>

    <%= f.select :supercategory, Cash.supercategories, { include_blank: false }, { class: 'form-select' } %>
  </div>

  <div class="form-group mt-3">
    <%= input(f, :formula) %>
  </div>

  <div class="form-check mt-3">
    <%= f.check_box :favorite, class: 'form-check-input' %>

    <%= f.label :favorite, class: 'form-check-label' %>
  </div>

  <div class="form-group mt-4">
    <%= f.submit class: 'btn btn-primary' %>
  </div>
<% end %>
