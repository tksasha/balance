<tr id="<%= dom_id cash %>">
  <td>
    <%= cash.name %>
  </td>

  <td>
    <div class="supercategory">
      <%= I18n.t(cash.supercategory, scope: 'cash.supercategory') %>
    </div>
  </td>

  <td class="text-right">
    <%= money cash.sum %>
  </td>

  <td class="text-right">
    <%= link_to 'Редагувати', [:edit, :backoffice, cash],
      data: { remote: true }, class: 'btn btn-sm btn-outline-primary' %>
  </td>

  <td class="text-right">
    <%= link_to 'Видалити', [:backoffice, cash],
      data: { remote: true, method: :delete, confirm: t(:destroy_confirmation) },
      class: 'btn btn-sm btn-outline-danger' %>
  </td>
</tr>
