<header>
  <div>
    <% months.each_with_index do |month, index| %>
      <% index += 1 %>

      <%= link_to month, items_path(year: current_date.year, month: index),
        class: "#{ 'active' if index == current_date.month }", remote: true %>
    <% end %>
  </div>

  <div>
    <% (2015..Date.today.year).each do |year| %>
      <%= link_to year, items_path(year: year, month: current_date.month),
        class: "#{ 'active' if year == current_date.year }", remote: true %>
    <% end %>
  </div>
</header>
