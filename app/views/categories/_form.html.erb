<%= simple_form_for resource, data: { remote: true }, wrapper: :horizontal_form_with_label_3 do |f| %>
  <%= f.input :name %>

  <div class="form-group row">
    <%= f.label :income, class: 'col-sm-3 form-control-label' %>

    <div class="col-sm-9">
      <%= f.check_box :income %>
    </div>
  </div>

  <div class="form-group row">
    <div class="col-sm-9 offset-sm-3">
      <div class="clearfix">
        <div class="float-left">
          <%= f.button :submit, class: 'btn btn-primary' %>
        </div>

        <div class="float-right">
          <%= link_to 'Повернутися', :categories, data: { remote: true } %>
        </div>
      </div>
    </div>
  </div>
<% end %>
