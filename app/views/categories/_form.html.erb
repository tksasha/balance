<%= simple_form_for resource, remote: true, html: { autocomplete: :off } do |f| %>
  <%= f.hidden_field :currency %>

  <%= f.input :name %>

  <div class="form-group">
    <div class="form-check">
      <%= f.check_box :income, class: 'form-check-input' %>

      <%= f.label :income, class: 'form-check-label' %>
    </div>
  </div>

  <div class="form-group">
    <div class="form-check">
      <%= f.check_box :visible, class: 'form-check-input' %>

      <%= f.label :visible, class: 'form-check-label' %>
    </div>
  </div>

  <div class="clearfix">
    <div class="float-left">
      <%= f.button :submit, class: 'btn btn-primary' %>
    </div>

    <div class="float-right">
      <%= link_to 'Повернутися', :categories, data: { remote: true } %>
    </div>
  </div>
<% end %>
